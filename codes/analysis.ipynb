import pandas as pd
import numpy as np

from datasets import load_dataset

ds = load_dataset("Krishnan15/Personal_FinanceDataset")
print(ds)

pf = ds['train'].to_pandas()
pf.head()

print(pf.columns)

#total spent over each category
print(pf.groupby('Category')['Amount'].sum())

#total spent over date
print(pf.groupby('Date')['Amount'].sum())

#total spent over each month
print(pf.groupby('Month')['Amount'].sum())

print(pf.isnull().sum())

#conversion to csv for database and python to use
pf.to_csv('finance_closed.csv',index=False)
